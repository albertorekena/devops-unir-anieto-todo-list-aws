pipeline {
    agent none

    stages {
        stage('Get Code') {
            agent { label 'built-in' }
            options { skipDefaultCheckout() }
            steps {
                cleanWs()
                git branch: 'develop', url: 'https://github.com/albertorekena/devops-unir-anieto-todo-list-aws'
                sh '''
                    curl -o samconfig.toml https://raw.githubusercontent.com/albertorekena/devops-unir-anieto-todo-list-aws-config/staging/samconfig.toml
                    grep -q "^version" samconfig.toml || sed -i "1s/^/version = 0.1\\n/" samconfig.toml
                '''
            }
        }

        stage('Deploy') {
            agent { label 'built-in' }
            steps {
                sh """
                    aws sts get-caller-identity
                    sam build
                    sam validate --region us-east-1
                    sam deploy --config-env production \\
                        --config-file samconfig.toml \\
                        --no-confirm-changeset \\
                        --no-disable-rollback \\
                        --no-fail-on-empty-changeset
                """
            }
        }

        stage('Rest Test') {
            agent { label 'built-in' }
            steps {
                sh """
                    export BASE_URL=\$(aws cloudformation describe-stacks --stack-name devops-unir-anieto-todo-list-aws-production --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" --output text)
                    export PYTHONPATH=\$WORKSPACE
                    python3 -m pytest -m readonly --junitxml=result-rest.xml test/integration/todoApiTest.py
                """
                junit 'result-rest.xml'
            }
        }

        stage('Promote') {
            agent { label 'built-in' }
            steps {
                sshagent(credentials: ['github-ssh']) {
                    sh '''
                        git config user.email "jenkins@jenkins.com"
                        git config user.name "Jenkins"
                        ssh-keyscan github.com >> ~/.ssh/known_hosts
                        git remote set-url origin git@github.com:albertorekena/devops-unir-anieto-todo-list-aws.git
                        git fetch origin
                        git checkout master
                        git merge -X theirs develop
                        git push origin master
                    '''
                }
            }
        }

        stage('Clean Workspace') {
            agent { label 'built-in' }
            steps {
                cleanWs()
            }
        }
    }
}