pipeline {
    agent none

    stages {
        stage('Get Code') {
            agent { label 'built-in' }
            options { skipDefaultCheckout() }
            steps {
                cleanWs()
                git branch: 'master', url: 'https://github.com/albertorekena/devops-unir-anieto-todo-list-aws.git'
            }
        }

        stage('Deploy') {
            agent { label 'built-in' }
            steps {
                sh """
                    aws sts get-caller-identity
                    sam build
                    sam validate --region us-east-1
                    sam deploy --config-env production \\
                        --config-file samconfig.toml \\
                        --no-confirm-changeset \\
                        --no-disable-rollback \\
                        --no-fail-on-empty-changeset
                """
            }
        }

        stage('Rest Test') {
            agent { label 'built-in' }
            steps {
                sh """
                    export BASE_URL=\$(aws cloudformation describe-stacks --stack-name devops-unir-anieto-todo-list-aws-production --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" --output text)
                    export PYTHONPATH=\$WORKSPACE
                    python3 -m pytest -m readonly --junitxml=result-rest.xml test/integration/todoApiTest.py
                """
                junit 'result-rest.xml'
            }
        }
    }
}