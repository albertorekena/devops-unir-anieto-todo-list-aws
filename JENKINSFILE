pipeline {
    agent none

    stages {
        stage('Get Code') {
            agent { label 'built-in' }
            options { skipDefaultCheckout() }
            steps {
                cleanWs()
                checkout scm
                script {
                    env.BRANCH = env.GIT_BRANCH.replaceAll('origin/', '')
                }
            }
        }

        stage('Static Tests') {
            when {
                expression { return env.BRANCH == 'develop' }
            }
            parallel {
                stage('Static') {
                    agent { label 'built-in' }
                    steps {
                        catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                            sh 'python3 -m flake8 --format=pylint --exit-zero src/ > flake8.out'
                        }
                        recordIssues tools: [flake8(pattern: 'flake8.out')], enabledForFailure: true
                    }
                }

                stage('Security') {
                    agent { label 'built-in' }
                    steps {
                        sh 'python3 -m bandit -r src/ -f custom -o bandit.out --msg-template "{abspath}:{line}: [{test_id}] {msg}" --exit-zero'
                        recordIssues tools: [pyLint(name: 'Bandit', pattern: 'bandit.out')], enabledForFailure: true
                    }
                }
            }
        }

        stage('Deploy') {
            agent { label 'built-in' }
            steps {
                script {
                    def configEnv = (env.BRANCH == 'master') ? 'production' : 'staging'
                    sh """
                        aws sts get-caller-identity
                        sam build
                        sam validate --region us-east-1
                        sam deploy --config-env ${configEnv} \\
                            --config-file samconfig.toml \\
                            --no-confirm-changeset \\
                            --no-disable-rollback \\
                            --no-fail-on-empty-changeset
                    """
                }
            }
        }

        stage('Rest Test') {
            agent { label 'built-in' }
            steps {
                script {
                    def isMaster = env.BRANCH == 'master'
                    def stackSuffix = isMaster ? 'production' : 'staging'
                    def pytestMark = isMaster ? '-m readonly' : ''
                    sh """
                        export BASE_URL=\$(aws cloudformation describe-stacks --stack-name devops-unir-anieto-todo-list-aws-${stackSuffix} --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" --output text)
                        export PYTHONPATH=\$WORKSPACE
                        python3 -m pytest ${pytestMark} --junitxml=result-rest.xml test/integration/todoApiTest.py
                    """
                }
                junit 'result-rest.xml'
            }
        }

        stage('Promote') {
            when {
                expression { return env.BRANCH == 'develop' }
                beforeAgent true
            }
            agent { label 'built-in' }
            steps {
                sshagent(credentials: ['github-ssh']) {
                    sh '''
                        git config user.email "jenkins@jenkins.com"
                        git config user.name "Jenkins"
                        ssh-keyscan github.com >> ~/.ssh/known_hosts
                        git remote set-url origin git@github.com:albertorekena/devops-unir-anieto-todo-list-aws.git
                        git fetch origin
                        git checkout master
                        git merge develop
                        git push origin master
                    '''
                }
            }
        }

        stage('Clean Workspace') {
            agent { label 'built-in' }
            steps {
                cleanWs()
            }
        }
    }
}
