pipeline {
    agent none

    stages {
        stage('Get Code') {
            agent { label 'built-in' }
            options { skipDefaultCheckout() }
            steps {
                cleanWs()
                git branch: 'master', url: 'https://github.com/albertorekena/devops-unir-anieto-todo-list-aws'
                stash name: 'workspace', includes: '**'
            }
        }

        stage('Static Tests') {
        parallel {
            stage('Static') {
                agent { label 'static' }
                steps {
                    unstash 'workspace'
                    catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                        sh 'python3 -m flake8 --format=pylint --exit-zero src/ > flake8.out'
                    }
                    recordIssues tools: [flake8(pattern: 'flake8.out')], enabledForFailure: true
                }
            }

            stage('Security') {
                agent { label 'static' }
                steps {
                    unstash 'workspace'
                    sh 'python3 -m bandit -r src/ -f custom -o bandit.out --msg-template "{abspath}:{line}: [{test_id}] {msg}" --exit-zero'
                    recordIssues tools: [pyLint(name: 'Bandit', pattern: 'bandit.out')], enabledForFailure: true
                }
            }
        }}

        stage('Deploy') {
            agent { label 'built-in' }
            steps {
                sh '''
                    aws sts get-caller-identity
                    sam build
                    sam validate --region us-east-1
                    sam deploy --config-env production \
                        --config-file samconfig.toml \
                        --no-confirm-changeset \
                        --no-disable-rollback \
                        --no-fail-on-empty-changeset
                '''
                sh '''
                    aws cloudformation describe-stacks \
                        --stack-name devops-unir-anieto-todo-list-aws-production \
                        --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" \
                        --output text > base_url.txt
                '''
                stash name: 'base-url', includes: 'base_url.txt'
            }
        }

        stage('Rest Test') {
            agent { label 'rest' }
            steps {
                unstash 'workspace'
                unstash 'base-url'
                sh '''
                    export BASE_URL=$(cat base_url.txt)
                    export PYTHONPATH=$WORKSPACE
                    python3 -m pytest -m "readonly" --junitxml=result-rest.xml test/integration/todoApiTest.py
                '''
                junit 'result-rest.xml'
            }
        }

stage('Clean Workspace') {
            agent { label 'built-in' }
            steps {
                cleanWs()
            }
        }
    }
}
