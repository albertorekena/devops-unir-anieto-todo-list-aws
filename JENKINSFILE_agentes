pipeline {
    agent none

    stages {
        stage('Get Code') {
            agent { label 'built-in' }
            options { skipDefaultCheckout() }
            steps {
                sh 'whoami && hostname'
                cleanWs()
                git branch: 'master', url: 'https://github.com/albertorekena/devops-unir-anieto-todo-list-aws'
                sh '''
                    curl -o samconfig.toml https://raw.githubusercontent.com/albertorekena/devops-unir-anieto-todo-list-aws-config/production/samconfig.toml
                '''
                stash name: 'workspace', includes: '**'
            }
        }

        stage('Deploy') {
            agent { label 'built-in' }
            steps {
                sh 'whoami && hostname'
                sh '''
                    aws sts get-caller-identity
                    sam build
                    sam validate --region us-east-1
                    sam deploy --config-env production \
                        --config-file samconfig.toml \
                        --no-confirm-changeset \
                        --no-disable-rollback \
                        --no-fail-on-empty-changeset
                '''
                sh '''
                    aws cloudformation describe-stacks \
                        --stack-name devops-unir-anieto-todo-list-aws-production \
                        --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" \
                        --output text > base_url.txt
                '''
                stash name: 'base-url', includes: 'base_url.txt'
            }
        }

        stage('Rest Test') {
            agent { label 'rest' }
            steps {
                sh 'whoami && hostname'
                unstash 'workspace'
                unstash 'base-url'
                sh '''
                    export BASE_URL=$(cat base_url.txt)
                    export PYTHONPATH=$WORKSPACE
                    python3 -m pytest -m readonly --junitxml=result-rest.xml test/integration/todoApiTest.py
                '''
                junit 'result-rest.xml'
            }
        }

        stage('Clean Workspace') {
            agent { label 'built-in' }
            steps {
                sh 'whoami && hostname'
                cleanWs()
            }
        }
    }
}
